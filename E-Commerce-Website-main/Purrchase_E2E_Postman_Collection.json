    {
      "name": "3. Cart",
      "item": [
        {
          "name": "3.1 Get Cart",
          "event": [
            {
              "listen": "test",
              "script": { "exec": ["pm.test('Status 200', () => pm.response.to.have.status(200));"] }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "http://localhost:5001/api/cart",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5001",
              "path": ["api", "cart"]
            }
          }
        },
        {
          "name": "3.2 Add to Cart",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const cart = res.data || res.cart || res;",
                  "if (cart.items && cart.items.length > 0) {",
                  "  pm.collectionVariables.set('cartItemId', cart.items[cart.items.length - 1]._id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"productId\": \"{{productId}}\",\n  \"quantity\": 2,\n  \"size\": \"M\"\n}"
            },
            "url": {
              "raw": "http://localhost:5001/api/cart/add",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5001",
              "path": ["api", "cart", "add"]
            }
          }
        },
        {
          "name": "3.3 Update Cart Item",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"quantity\": 3\n}" },
            "url": {
              "raw": "http://localhost:5001/api/cart/update/{{cartItemId}}",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5001",
              "path": ["api", "cart", "update", "{{cartItemId}}"]
            }
          }
        },
        {
          "name": "3.4 Remove from Cart",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "http://localhost:5001/api/cart/remove/{{cartItemId}}",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5001",
              "path": ["api", "cart", "remove", "{{cartItemId}}"]
            }
          }
        },
        {
          "name": "3.5 Clear Cart",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "http://localhost:5001/api/cart/clear",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5001",
              "path": ["api", "cart", "clear"]
            }
          }
        }
