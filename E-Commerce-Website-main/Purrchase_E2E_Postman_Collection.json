    {
      "name": "2. Products",
      "item": [
        {
          "name": "2.1 Get All Products",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const products = res.data?.products || res.data || res.products || [];",
                  "if (products.length > 0) { pm.collectionVariables.set('productId', products[0]._id); }"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "http://localhost:5001/api/products",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5001",
              "path": ["api", "products"]
            }
          }
        },
        {
          "name": "2.2 Get Featured Products",
          "event": [
            {
              "listen": "test",
              "script": { "exec": ["pm.test('Status 200', () => pm.response.to.have.status(200));"] }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "http://localhost:5001/api/products/featured?limit=8",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5001",
              "path": ["api", "products", "featured"],
              "query": [{ "key": "limit", "value": "8" }]
            }
          }
        },
        {
          "name": "2.3 Get Categories",
          "event": [
            {
              "listen": "test",
              "script": { "exec": ["pm.test('Status 200', () => pm.response.to.have.status(200));"] }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "http://localhost:5001/api/products/categories/list",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5001",
              "path": ["api", "products", "categories", "list"]
            }
          }
        },
        {
          "name": "2.4 Filter by Category (electronics)",
          "event": [
            {
              "listen": "test",
              "script": { "exec": ["pm.test('Status 200', () => pm.response.to.have.status(200));"] }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "http://localhost:5001/api/products?category=electronics",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5001",
              "path": ["api", "products"],
              "query": [{ "key": "category", "value": "electronics" }]
            }
          }
        },
        {
          "name": "2.5 Search Products",
          "event": [
            {
              "listen": "test",
              "script": { "exec": ["pm.test('Status 200', () => pm.response.to.have.status(200));"] }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "http://localhost:5001/api/products/search?q=shirt",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5001",
              "path": ["api", "products", "search"],
              "query": [{ "key": "q", "value": "shirt" }]
            }
          }
        },
        {
          "name": "2.6 Get Product by ID",
          "event": [
            {
              "listen": "test",
              "script": { "exec": ["pm.test('Status 200', () => pm.response.to.have.status(200));"] }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "http://localhost:5001/api/products/{{productId}}",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5001",
              "path": ["api", "products", "{{productId}}"]
            }
          }
        },
        {
          "name": "2.7 Create Product",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "const id = res.data?._id || res.product?._id;",
                  "if (id) { pm.collectionVariables.set('productId', id); }"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Test Product Postman\",\n  \"price\": 999,\n  \"category\": \"electronics\",\n  \"description\": \"Test product created via Postman E2E\",\n  \"images\": [\"https://via.placeholder.com/300\"],\n  \"brand\": \"TestBrand\",\n  \"stock\": 50,\n  \"sizes\": [\"M\", \"L\"],\n  \"rating\": 4.5,\n  \"numReviews\": 10,\n  \"featured\": false\n}"
            },
            "url": {
              "raw": "http://localhost:5001/api/products",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5001",
              "path": ["api", "products"]
            }
          }
