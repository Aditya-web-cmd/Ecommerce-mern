{
  "info": {
    "name": "Purrchase E-Commerce - E2E Testing",
    "description": "End-to-end API testing for Purrchase E-Commerce. Base URL: http://localhost:5001/api",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "token", "value": "" },
    { "key": "productId", "value": "" },
    { "key": "cartItemId", "value": "" },
    { "key": "orderId", "value": "" }
